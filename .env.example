# ============================================
# Sovereign AI — Environment Variables
# ============================================
# Copy to .env and fill in your keys.
# NEVER commit .env to git.
# ============================================

# ── Core Secrets ─────────────────────────────
WEBUI_SECRET_KEY=change-me-to-something-random-32chars
NOTEBOOK_SECRET_KEY=change-me-notebook-secret

# Host workspace path mounted into MCP and agent containers.
# Defaults to the repo root when unset; widen it only if you want broader file access.
HOST_WORK_DIR=.

# ── Search ───────────────────────────────────
# Brave Search: https://brave.com/search/api/  (free: 2000/mo)
BRAVE_API_KEY=

# Exa Search: https://exa.ai  (free tier available)
EXA_API_KEY=

# Firecrawl: https://firecrawl.dev  (free: 500 pages/mo)
FIRECRAWL_API_KEY=

# ── AI Providers ─────────────────────────────
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google AI Studio: https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Groq (fast inference, free tier): https://console.groq.com/keys
GROQ_API_KEY=

# Mistral: https://console.mistral.ai/
MISTRAL_API_KEY=

# NVIDIA NIM (free tier): https://build.nvidia.com/
NVIDIA_API_KEY=

# OpenRouter (aggregator): https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Together AI: https://api.together.xyz/
TOGETHER_API_KEY=

# ── Developer Tools ───────────────────────────
# GitHub PAT (repo + read:org): https://github.com/settings/tokens
GITHUB_TOKEN=

# Google Maps: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=

# ── Multi-Provider Config ─────────────────────
# Comma-separated URLs and matching keys (position matters).
# Example with OpenAI + Groq + NVIDIA:
OPENAI_API_BASE_URLS=https://api.openai.com/v1,https://api.groq.com/openai/v1,https://integrate.api.nvidia.com/v1
OPENAI_API_KEYS=${OPENAI_API_KEY},${GROQ_API_KEY},${NVIDIA_API_KEY}

# ── Database ──────────────────────────────────
# Leave empty to run Qdrant without auth (local only)
QDRANT_API_KEY=

# ── Image Generation ──────────────────────────
# Stability AI: https://platform.stability.ai/
STABILITY_API_KEY=

# Replicate: https://replicate.com/account/api-tokens
REPLICATE_API_KEY=

# ── Voice / Audio ─────────────────────────────
# ElevenLabs: https://elevenlabs.io/
ELEVENLABS_API_KEY=
